# PaganCMS — Environment Configuration
# Skopiuj ten plik jako .env i dostosuj wartości

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRY_HOURS=24

# Database
DATABASE_URL=sqlite:data/pagancms.db?mode=rwc

# Server
SERVER_ADDR=0.0.0.0:3000

# Gitea Integration
GITEA_API_URL=https://git.paganlinux.eu/api/v1
GITEA_TOKEN=your-gitea-api-token-here

# CORS
CORS_ORIGIN=http://localhost:5173

# Redis (for build queue)
REDIS_URL=redis://localhost:6379
