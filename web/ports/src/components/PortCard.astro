---
// Komponent: Karta portu
export interface Props {
  port: import('../lib/github').PortEntry;
}

const { port } = Astro.props;
---

<a href={`/port/${port.name}`} class="port-card">
  <div class="port-header">
    <span class="port-name">{port.name}</span>
    <span class="port-version">{port.version}-r{port.release}</span>
  </div>
  <p class="port-desc">{port.description}</p>
  <div class="port-meta">
    <span class="meta-item">{port.license}</span>
    <span class="meta-item">{port.arch}</span>
    {port.maintainer && <span class="meta-item">👤 {port.maintainer.split('<')[0].trim()}</span>}
    <span class="meta-item">📦 {port.makedepends.length} makedeps</span>
  </div>
</a>

<style>
  .port-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-decoration: none;
    color: var(--fg);
    display: block;
    transition: border-color 0.2s, transform 0.2s;
  }
  .port-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .port-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .port-name {
    font-weight: 700;
    color: var(--accent2);
    font-size: 1.1rem;
  }
  .port-version {
    color: var(--green);
    font-size: 0.9rem;
    font-family: 'Fira Code', monospace;
  }
  .port-desc {
    color: #9090a0;
    font-size: 0.9rem;
    margin-bottom: 0.8rem;
    line-height: 1.5;
  }
  .port-meta {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .meta-item {
    background: rgba(255,255,255,0.03);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.8rem;
    color: #808090;
  }
</style>
