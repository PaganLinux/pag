---
// Komponent: Nawigacja dla pagports
---

<nav>
  <div class="nav-inner">
    <a href="/" class="logo">
      <span class="logo-icon">🏗️</span>
      <span>pagports.paganlinux.eu</span>
    </a>
    <div class="nav-links">
      <a href="https://paganlinux.eu">← paganlinux.eu</a>
      <a href="https://repos.paganlinux.eu">Repozytorium</a>
      <a href="https://github.com/PaganLinux/pagports" target="_blank">GitHub</a>
    </div>
  </div>
</nav>

<style>
  nav {
    background: rgba(10,10,15,0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .nav-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 58px;
    padding: 0 2rem;
  }
  .logo {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--accent2);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .logo-icon { font-size: 1.4rem; }
  .nav-links { display: flex; gap: 1.2rem; align-items: center; }
  .nav-links a {
    color: #b0b0c0;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--accent2); }

  @media (max-width: 640px) {
    .nav-links a:first-of-type { display: none; }
  }
</style>
