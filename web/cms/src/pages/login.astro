---
import Layout from '../components/Layout.astro';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const username = data.get('username')?.toString() || '';
    const password = data.get('password')?.toString() || '';

    const res = await fetch('http://localhost:3005/api/v1/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username, password }),
    });

    if (res.ok) {
      const json = await res.json();
      Astro.cookies.set('pagan_cms_session', json.token, {
        path: '/',
        httpOnly: true,
        sameSite: 'strict',
        maxAge: 60 * 60 * 24 * 7,
      });
      return Astro.redirect('/');
    }

    const err = await res.json().catch(() => ({ error: 'Login failed' }));
    return new Response(JSON.stringify({ error: err.error }), {
      status: 401,
      headers: { 'Content-Type': 'application/json' },
    });
  } catch (e) {
    return new Response(JSON.stringify({ error: 'Connection error' }), {
      status: 500,
      headers: { 'Content-Type': 'application/json' },
    });
  }
}
---

<Layout title="Login" showNav={false}>
  <div class="login-page">
    <div class="login-card">
      <h1>🔐 paganOS CMS</h1>
      <p class="subtitle">Panel administracyjny</p>

      <div id="error-container"></div>

      <form id="login-form" method="post">
        <div class="form-group">
          <label for="username">Nazwa użytkownika</label>
          <input type="text" id="username" name="username" placeholder="admin" required autofocus />
        </div>
        <div class="form-group">
          <label for="password">Hasło</label>
          <input type="password" id="password" name="password" placeholder="••••••••" required />
        </div>
        <button type="submit" class="btn btn-primary btn-full">Zaloguj się</button>
      </form>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorDiv = document.getElementById('error-container')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const username = fd.get('username') as string;
    const password = fd.get('password') as string;

    try {
      const res = await fetch('http://localhost:3005/api/v1/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, password }),
      });

      if (res.ok) {
        const json = await res.json();
        localStorage.setItem('cms_token', json.token);
        window.location.href = '/';
      } else {
        const err = await res.json();
        errorDiv.innerHTML = `<div class="error-msg">${err.error || 'Login failed'}</div>`;
      }
    } catch {
      errorDiv.innerHTML = '<div class="error-msg">Connection error. Is the CMS backend running?</div>';
    }
  });
</script>
