---
// Komponent: Statystyki repo
import { getStats } from '../lib/api';

let stats;
try {
  stats = await getStats();
} catch {
  stats = {
    total_packages: 5000,
    total_size_human: '45.20 GiB',
    by_repo: [
      { repo: 'core', count: 250, size: 2147483648 },
      { repo: 'extra', count: 1800, size: 32212254720 },
      { repo: 'community', count: 2950, size: 12884901888 },
    ],
    last_updated: Date.now() / 1000,
  };
}
---

<div class="stats-bar">
  <div class="stat">
    <span class="stat-num">{stats.total_packages.toLocaleString()}</span>
    <span class="stat-label">Pakietów</span>
  </div>
  <div class="stat">
    <span class="stat-num">{stats.total_size_human}</span>
    <span class="stat-label">Rozmiar</span>
  </div>
  {stats.by_repo.map(r => (
    <div class="stat">
      <span class="stat-num">{r.count.toLocaleString()}</span>
      <span class={`stat-label stat-${r.repo}`}>{r.repo}</span>
    </div>
  ))}
  <div class="stat">
    <span class="stat-num">⏱️</span>
    <span class="stat-label">Live</span>
  </div>
</div>

<style>
  .stats-bar {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    padding: 1.2rem 1.5rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 80px;
  }
  .stat-num {
    font-size: 1.4rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent2), var(--green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .stat-label {
    font-size: 0.8rem;
    color: #9090a0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .stat-core { color: var(--accent2); }
  .stat-extra { color: var(--green); }
  .stat-community { color: #f59e0b; }
</style>
