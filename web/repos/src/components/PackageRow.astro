---
// Komponent: Karta pakietu
export interface Props {
  pkg: import('../lib/api').PackageEntry;
}

const { pkg } = Astro.props;
const repoBadgeClass = `badge badge-${pkg.repo}`;
const sizeHuman = formatSize(pkg.installed_size);

function formatSize(bytes: number): string {
  const units = ['B', 'KiB', 'MiB', 'GiB'];
  let size = bytes, idx = 0;
  while (size >= 1024 && idx < units.length - 1) { size /= 1024; idx++; }
  return `${size.toFixed(1)} ${units[idx]}`;
}
---

<tr>
  <td>
    <a href={`/package/${pkg.name}`} class="pkg-name">
      {pkg.name}
    </a>
  </td>
  <td><span class="pkg-ver">{pkg.version}-r{pkg.release}</span></td>
  <td><span class={repoBadgeClass}>{pkg.repo}</span></td>
  <td><span class="pkg-arch">{pkg.arch}</span></td>
  <td class="size">{sizeHuman}</td>
  <td class="desc">{pkg.description}</td>
</tr>

<style>
  .pkg-name { font-weight: 600; color: var(--accent2); text-decoration: none; }
  .pkg-name:hover { text-decoration: underline; }
  .pkg-ver { color: var(--green); font-family: 'Fira Code', monospace; font-size: 0.9rem; }
  .pkg-arch { background: var(--card); padding: 0.15rem 0.45rem; border-radius: 4px; font-size: 0.8rem; color: #a0a0b0; }
  .size { color: #9090a0; font-size: 0.9rem; white-space: nowrap; }
  .desc { color: #b0b0c0; font-size: 0.9rem; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .badge { display: inline-block; padding: 0.15rem 0.55rem; border-radius: 5px; font-size: 0.8rem; font-weight: 600; text-transform: capitalize; }
  .badge-core { background: rgba(124,58,237,0.2); color: var(--accent2); }
  .badge-extra { background: rgba(16,185,129,0.2); color: var(--green); }
  .badge-community { background: rgba(245,158,11,0.2); color: #f59e0b; }

  @media (max-width: 768px) {
    .desc { display: none; }
  }
  @media (max-width: 480px) {
    .size { display: none; }
  }
</style>
