---
// repos.paganlinux.eu/package/[name] — Szczegóły pakietu
import Nav from '../../components/Nav.astro';
import { getPackage, getFallbackPackages } from '../../lib/api';

const { name } = Astro.params;

let pkg = null;
let error = null;

try {
  pkg = await getPackage(name);
} catch {
  // Fallback do danych demo
  const fallback = getFallbackPackages().find(p => p.name === name);
  if (fallback) {
    pkg = {
      ...fallback,
      filename: `${name}-${fallback.version}-r${fallback.release}-${fallback.arch}.pag`,
      sha512: 'a1b2c3d4e5f6...',
      blake3: 'f6e5d4c3b2a1...',
      maintainer: 'PaganLinux Team',
      license: 'GPL-2.0 / MIT / custom',
      upload_date: Math.floor(Date.now() / 1000) - 86400 * 7,
      depends: ['glibc', 'openssl'],
      provides: [],
      conflicts: [],
      download_count: 1234,
    };
    error = '⚠️ Tryb offline — dane demonstracyjne';
  }
}

if (!pkg) {
  return new Response(null, {
    status: 302,
    headers: { Location: '/?error=notfound' },
  });
}

const dateStr = new Date(pkg.upload_date * 1000).toLocaleDateString('pl-PL', {
  year: 'numeric', month: 'long', day: 'numeric',
});

function formatSize(bytes: number): string {
  const units = ['B', 'KiB', 'MiB', 'GiB'];
  let size = bytes, idx = 0;
  while (size >= 1024 && idx < units.length - 1) { size /= 1024; idx++; }
  return `${size.toFixed(1)} ${units[idx]}`;
}
---

<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pkg.name} {pkg.version}-r{pkg.release} — PaganLinux Repository</title>
  <meta name="description" content={pkg.description} />
  <style>
    :root {
      --bg: #0a0a0f; --bg2: #12121a; --fg: #e0e0e0;
      --accent: #7c3aed; --accent2: #a78bfa; --green: #10b981;
      --card: #1a1a2e; --border: #2a2a3e; --radius: 12px;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      background: var(--bg); color: var(--fg); line-height: 1.6; min-height: 100vh;
    }
    .container { max-width: 1000px; margin: 0 auto; padding: 2rem; }

    .breadcrumb {
      display: flex; gap: 0.5rem; margin-bottom: 2rem; font-size: 0.9rem; color: #808090;
    }
    .breadcrumb a { color: var(--accent2); text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }

    .pkg-header {
      background: var(--card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 2rem; margin-bottom: 1.5rem;
    }
    .pkg-title {
      display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap;
    }
    .pkg-title h1 { font-size: 2rem; color: var(--accent2); }
    .pkg-title .version {
      font-size: 1.3rem; color: var(--green); font-family: 'Fira Code', monospace;
    }
    .pkg-desc { color: #b0b0c0; font-size: 1.1rem; margin-top: 0.5rem; }

    .meta-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem; margin-bottom: 2rem;
    }

    .meta-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 1.5rem;
    }
    .meta-card h3 {
      font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;
      color: #808090; margin-bottom: 1rem;
    }

    .info-row {
      display: flex; justify-content: space-between; padding: 0.4rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.03); font-size: 0.95rem;
    }
    .info-label { color: #808090; }
    .info-value { color: var(--fg); font-weight: 500; }

    .tag-list { display: flex; flex-wrap: wrap; gap: 0.4rem; }
    .tag {
      background: rgba(124,58,237,0.15); color: var(--accent2);
      padding: 0.2rem 0.7rem; border-radius: 6px; font-size: 0.85rem;
      font-family: 'Fira Code', monospace;
    }
    .tag.empty { background: transparent; color: #606070; font-style: italic; }

    .install-box {
      background: #0a0a0f; border: 1px solid var(--border);
      border-radius: var(--radius); padding: 1.5rem; margin-bottom: 1.5rem;
    }
    .install-box h3 { color: var(--green); margin-bottom: 0.8rem; font-size: 1rem; }
    .install-box code {
      display: block; background: #000; padding: 1rem; border-radius: 6px;
      font-family: 'Fira Code', monospace; color: var(--accent2); font-size: 0.9rem;
      overflow-x: auto;
    }
    .install-box .comment { color: #6b7280; }

    .download-box {
      background: var(--card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 1.5rem; margin-bottom: 1.5rem;
    }
    .download-link {
      display: inline-block; padding: 0.7rem 1.5rem; background: var(--accent);
      color: white; text-decoration: none; border-radius: 8px; font-weight: 600;
      transition: background 0.2s;
    }
    .download-link:hover { background: #6d28d9; }

    .error-banner {
      background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.3);
      padding: 0.6rem 1rem; border-radius: 8px; margin-bottom: 1rem;
      color: #f59e0b; font-size: 0.9rem;
    }

    footer {
      border-top: 1px solid var(--border); padding: 1.5rem 2rem;
      text-align: center; color: #606070; font-size: 0.85rem; margin-top: 3rem;
    }
    footer a { color: var(--accent2); text-decoration: none; }

    @media (max-width: 600px) {
      .pkg-title { flex-direction: column; gap: 0.3rem; }
      .pkg-title h1 { font-size: 1.5rem; }
    }
  </style>
</head>
<body>
  <Nav />

  <div class="container">
    <div class="breadcrumb">
      <a href="/">Repozytorium</a>
      <span>/</span>
      <span>{pkg.name}</span>
    </div>

    {error && <div class="error-banner">{error}</div>}

    <div class="pkg-header">
      <div class="pkg-title">
        <h1>{pkg.name}</h1>
        <span class="version">{pkg.version}-r{pkg.release}</span>
        <span class="tag">{pkg.repo}</span>
      </div>
      <p class="pkg-desc">{pkg.description}</p>
    </div>

    <div class="meta-grid">
      <div class="meta-card">
        <h3>📋 Informacje</h3>
        <div class="info-row"><span class="info-label">Architektura</span><span class="info-value">{pkg.arch}</span></div>
        <div class="info-row"><span class="info-label">Licencja</span><span class="info-value">{pkg.license}</span></div>
        <div class="info-row"><span class="info-label">Rozmiar (zainst.)</span><span class="info-value">{formatSize(pkg.installed_size)}</span></div>
        <div class="info-row"><span class="info-label">Rozmiar (spak.)</span><span class="info-value">{formatSize(pkg.compressed_size)}</span></div>
        <div class="info-row"><span class="info-label">Opiekun</span><span class="info-value">{pkg.maintainer || '—'}</span></div>
        <div class="info-row"><span class="info-label">Data uploadu</span><span class="info-value">{dateStr}</span></div>
        <div class="info-row"><span class="info-label">Pobrań</span><span class="info-value">{pkg.download_count?.toLocaleString() || '—'}</span></div>
      </div>

      <div class="meta-card">
        <h3>🔗 Zależności</h3>
        <div class="tag-list">
          {pkg.depends.length > 0
            ? pkg.depends.map(d => <a href={`/package/${d}`} class="tag">{d}</a>)
            : <span class="tag empty">Brak zależności</span>}
        </div>
      </div>

      <div class="meta-card">
        <h3>📤 Dostarcza</h3>
        <div class="tag-list">
          {pkg.provides.length > 0
            ? pkg.provides.map(p => <span class="tag">{p}</span>)
            : <span class="tag empty">Nic nie dostarcza</span>}
        </div>
      </div>

      <div class="meta-card">
        <h3>⚠️ Konflikty</h3>
        <div class="tag-list">
          {pkg.conflicts.length > 0
            ? pkg.conflicts.map(c => <span class="tag">{c}</span>)
            : <span class="tag empty">Brak konfliktów</span>}
        </div>
      </div>
    </div>

    <div class="install-box">
      <h3>📥 Instalacja</h3>
      <code>
        <span class="comment"># Zainstaluj pakiet</span>
        pag install {pkg.name}

        <span class="comment"># Albo pobierz ręcznie</span>
        pag download {pkg.name}
      </code>
    </div>

    <div class="download-box">
      <h3 style="margin-bottom:0.8rem;">🔽 Pobierz plik .pag</h3>
      <p style="color:#808090;margin-bottom:1rem;font-size:0.9rem;">
        {pkg.filename} · SHA512: <code style="font-family:monospace;font-size:0.8rem;">{pkg.sha512?.substring(0, 32)}...</code>
      </p>
      <a href={`/${pkg.repo}/x86_64/main/${pkg.filename}`} class="download-link">
        📥 Pobierz {pkg.name}-{pkg.version}-r{pkg.release}.pag
      </a>
    </div>
  </div>

  <footer>
    PaganLinux © 2026 · <a href="https://paganlinux.eu">paganlinux.eu</a> ·
    <a href="/api/v1/index.json">API JSON</a>
  </footer>
</body>
</html>
