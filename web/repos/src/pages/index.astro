---
// repos.paganlinux.eu — Strona główna z live search i listingiem
import Nav from '../components/Nav.astro';
import SearchBar from '../components/SearchBar.astro';
import PackageRow from '../components/PackageRow.astro';
import RepoStats from '../components/RepoStats.astro';
import { searchPackages, listPackages, getFallbackPackages } from '../lib/api';

const url = new URL(Astro.request.url);
const query = url.searchParams.get('q') || '';
const repo = url.searchParams.get('repo') || '';
const page = parseInt(url.searchParams.get('page') || '1');
const perPage = 50;

let packages = [];
let totalResults = 0;
let error = null;

try {
  if (query) {
    const results = await searchPackages(query);
    packages = results.results || [];
    totalResults = packages.length;
  } else {
    const data = await listPackages(repo || undefined);
    packages = data.packages || [];
    totalResults = packages.length;
  }
} catch (e) {
  packages = getFallbackPackages();
  if (query) {
    packages = packages.filter(p =>
      p.name.toLowerCase().includes(query.toLowerCase()) ||
      p.description.toLowerCase().includes(query.toLowerCase())
    );
  }
  if (repo) {
    packages = packages.filter(p => p.repo === repo);
  }
  totalResults = packages.length;
  error = '⚠️ Serwer API niedostępny — pokazuję dane demonstracyjne';
}

// Paginacja
const totalPages = Math.ceil(totalResults / perPage);
const start = (page - 1) * perPage;
const pagedPackages = packages.slice(start, start + perPage);
---

<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{query ? `"${query}" — ` : ''}Repozytorium PaganLinux</title>
  <meta name="description" content="Oficjalne repozytorium pakietów PaganLinux. Przeglądaj, szukaj i pobieraj pakiety .pag." />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📦</text></svg>" />
  <style>
    :root {
      --bg: #0a0a0f; --bg2: #12121a; --fg: #e0e0e0;
      --accent: #7c3aed; --accent2: #a78bfa; --green: #10b981;
      --card: #1a1a2e; --border: #2a2a3e; --radius: 12px;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      background: var(--bg); color: var(--fg); line-height: 1.6; min-height: 100vh;
    }
    .container { max-width: 1400px; margin: 0 auto; padding: 2rem; }
    h1 { font-size: 1.8rem; margin-bottom: 0.3rem; }
    .subtitle { color: #808090; margin-bottom: 1.5rem; font-size: 0.95rem; }

    .toolbar {
      display: flex; gap: 2rem; align-items: center; flex-wrap: wrap;
      margin-bottom: 1rem;
    }
    .results-info {
      color: #808090; font-size: 0.9rem;
    }
    .results-info strong { color: var(--accent2); }

    .repo-filters {
      display: flex; gap: 0; margin-bottom: 1rem;
    }
    .repo-filter {
      padding: 0.5rem 1.2rem; border: 1px solid var(--border);
      background: var(--card); color: #b0b0c0; cursor: pointer;
      font-size: 0.85rem; text-decoration: none;
      transition: all 0.2s;
    }
    .repo-filter:first-child { border-radius: 8px 0 0 8px; }
    .repo-filter:last-child { border-radius: 0 8px 8px 0; }
    .repo-filter.active, .repo-filter:hover {
      background: var(--accent); border-color: var(--accent); color: white;
    }

    table { width: 100%; border-collapse: collapse; }
    th {
      text-align: left; padding: 0.7rem 1rem; border-bottom: 2px solid var(--border);
      color: #808090; font-weight: 600; font-size: 0.82rem; text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    td { padding: 0.6rem 1rem; border-bottom: 1px solid var(--border); font-size: 0.92rem; }
    tbody tr:hover { background: rgba(124, 58, 237, 0.04); }

    .pagination {
      display: flex; gap: 0.5rem; justify-content: center; margin-top: 2rem;
    }
    .pagination a, .pagination span {
      padding: 0.5rem 0.9rem; border-radius: 6px; border: 1px solid var(--border);
      color: var(--fg); text-decoration: none; font-size: 0.9rem;
    }
    .pagination a:hover { background: var(--accent); border-color: var(--accent); color: white; }
    .pagination .current { background: var(--accent); border-color: var(--accent); color: white; font-weight: 600; }

    .error-banner {
      background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.3);
      padding: 0.7rem 1rem; border-radius: 8px; margin-bottom: 1rem;
      color: #f59e0b; font-size: 0.9rem;
    }

    .install-hint {
      margin-top: 2rem; padding: 1rem 1.2rem; background: var(--card);
      border: 1px solid var(--border); border-radius: var(--radius);
      color: #9090a0; font-size: 0.9rem;
    }
    .install-hint code {
      background: #0a0a0f; padding: 0.2rem 0.5rem; border-radius: 4px;
      color: var(--accent2); font-family: 'Fira Code', monospace; font-size: 0.85rem;
    }

    footer {
      border-top: 1px solid var(--border); padding: 1.5rem 2rem;
      text-align: center; color: #606070; font-size: 0.85rem; margin-top: 3rem;
    }
    footer a { color: var(--accent2); text-decoration: none; }
  </style>
</head>
<body>
  <Nav />

  <div class="container">
    <h1>📦 Repozytorium Pakietów PaganLinux</h1>
    <p class="subtitle">Oficjalne repozytorium pakietów .pag. Wszystkie pakiety są podpisane GPG i weryfikowane SHA512 + BLAKE3.</p>

    <RepoStats />

    <SearchBar />

    {error && <div class="error-banner">{error}</div>}

    <div class="repo-filters">
      <a href="/" class={`repo-filter ${!repo ? 'active' : ''}`}>Wszystkie</a>
      <a href="/?repo=core" class={`repo-filter ${repo === 'core' ? 'active' : ''}`}>Core</a>
      <a href="/?repo=extra" class={`repo-filter ${repo === 'extra' ? 'active' : ''}`}>Extra</a>
      <a href="/?repo=community" class={`repo-filter ${repo === 'community' ? 'active' : ''}`}>Community</a>
    </div>

    <div class="results-info">
      {query
        ? <>Wyniki dla "<strong>{query}</strong>" — <strong>{totalResults}</strong> pakietów</>
        : <><strong>{totalResults}</strong> pakietów {repo ? `w ${repo}` : 'łącznie'}</>
      }
    </div>

    <table>
      <thead>
        <tr>
          <th>Pakiet</th>
          <th>Wersja</th>
          <th>Repo</th>
          <th>Arch</th>
          <th>Rozmiar</th>
          <th>Opis</th>
        </tr>
      </thead>
      <tbody>
        {pagedPackages.length === 0 ? (
          <tr><td colspan="6" style="text-align:center;padding:3rem;color:#808090;">
            {query ? '🔍 Brak wyników. Spróbuj innego zapytania.' : '📭 Brak pakietów w tym repozytorium.'}
          </td></tr>
        ) : (
          pagedPackages.map(pkg => <PackageRow pkg={pkg} />)
        )}
      </tbody>
    </table>

    {totalPages > 1 && (
      <div class="pagination">
        {page > 1 && <a href={`/?q=${query}&repo=${repo}&page=${page - 1}`}>← Poprzednia</a>}
        {Array.from({ length: Math.min(totalPages, 7) }, (_, i) => {
          const p = i + Math.max(0, page - 4);
          if (p > totalPages) return null;
          return p === page
            ? <span class="current">{p}</span>
            : <a href={`/?q=${query}&repo=${repo}&page=${p}`}>{p}</a>;
        })}
        {page < totalPages && <a href={`/?q=${query}&repo=${repo}&page=${page + 1}`}>Następna →</a>}
      </div>
    )}

    <div class="install-hint">
      💡 Aby dodać repozytorium: <code>pag repo add core https://repos.paganlinux.eu/core</code> &nbsp;|&nbsp;
      Instalacja: <code>pag install nazwa-pakietu</code>
    </div>
  </div>

  <footer>
    PaganLinux © 2026 · <a href="https://paganlinux.eu">paganlinux.eu</a> ·
    <a href="https://github.com/PaganLinux/pag">GitHub</a> ·
    Strona renderowana dynamicznie — dane z API
  </footer>
</body>
</html>
