---
// Admin — Dashboard
import AdminLayout from '../../layouts/AdminLayout.astro';

// W produkcji dane będą pobierane z API
const stats = {
  packages: 231,
  built: 0,
  isos: 0,
  buildsToday: 0,
};
---
<AdminLayout>
  <h1>📊 Dashboard</h1>
  <p class="subtitle">Przegląd stanu PaganLinux</p>

  <div class="admin-cards">
    <div class="admin-card">
      <div class="card-num">{stats.packages}</div>
      <div class="card-label">📦 Portów w pagports</div>
    </div>
    <div class="admin-card">
      <div class="card-num">{stats.built}</div>
      <div class="card-label">🏗️ Zbudowanych .pag</div>
    </div>
    <div class="admin-card">
      <div class="card-num">{stats.isos}</div>
      <div class="card-label">💿 Obrazów ISO</div>
    </div>
    <div class="admin-card">
      <div class="card-num">{stats.buildsToday}</div>
      <div class="card-label">🔄 Buildów dziś</div>
    </div>
  </div>

  <h2 style="font-size:1.1rem;margin-bottom:0.8rem;">Szybkie akcje</h2>
  <div style="display:flex;gap:0.6rem;flex-wrap:wrap;">
    <a href="/admin/ports" class="admin-btn primary">🏗️ Buduj pakiety</a>
    <a href="/admin/isos" class="admin-btn">💿 Zarządzaj ISO</a>
    <a href="/admin/packages" class="admin-btn">📦 Przeglądaj pakiety</a>
  </div>
</AdminLayout>
