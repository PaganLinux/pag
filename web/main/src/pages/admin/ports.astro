---
// Admin — Porty + budowanie
import AdminLayout from '../../layouts/AdminLayout.astro';

const ports = [
  { name: '7zip', version: '24.09', status: 'ready', category: 'core' },
  { name: 'nginx', version: '1.26.0', status: 'building', category: 'core' },
  { name: 'hyprland', version: '0.45.0', status: 'ready', category: 'wayland' },
  { name: 'firefox', version: '131.0', status: 'error', category: 'desktop' },
];
---
<AdminLayout>
  <h1>🏗️ Porty / Budowanie</h1>
  <p class="subtitle">Zarządzaj portami pagbuild i uruchamiaj budowanie</p>

  <div style="display:flex;gap:0.6rem;margin-bottom:1rem;">
    <form method="POST" action="/admin/api/build" style="display:flex;gap:0.5rem;flex:1;">
      <input type="text" name="port" placeholder="Nazwa portu (np. nginx)..." style="flex:1;" class="admin-field input" />
      <button type="submit" class="admin-btn primary">🏗️ Buduj</button>
    </form>
    <a href="/admin/builds" class="admin-btn">🔄 Historia</a>
  </div>

  <table class="admin-table">
    <thead>
      <tr>
        <th>Port</th>
        <th>Wersja</th>
        <th>Kategoria</th>
        <th>Status</th>
        <th>Akcje</th>
      </tr>
    </thead>
    <tbody>
      {ports.length === 0 ? (
        <tr><td colspan="5" class="empty">Ładowanie portów z GitHub...</td></tr>
      ) : ports.map(port => (
        <tr>
          <td><strong>{port.name}</strong></td>
          <td><span class="admin-tag green">{port.version}</span></td>
          <td><span class="admin-tag blue">{port.category}</span></td>
          <td>
            {port.status === 'ready' && <span class="admin-tag green">✅ Gotowy</span>}
            {port.status === 'building' && <span class="admin-tag yellow">🔄 Buduje się</span>}
            {port.status === 'error' && <span class="admin-tag red">❌ Błąd</span>}
          </td>
          <td style="display:flex;gap:0.3rem;">
            <form method="POST" action="/admin/api/build">
              <input type="hidden" name="port" value={port.name} />
              <button class="admin-btn small primary">🏗️ Buduj</button>
            </form>
            <button class="admin-btn small">📄 Pagbuild</button>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</AdminLayout>

<style>
  .admin-field.input {
    padding: 0.6rem 0.8rem;
    border-radius: 8px;
    border: 1px solid var(--admin-border);
    background: var(--admin-card);
    color: var(--admin-fg);
    font-size: 0.9rem;
  }
  .admin-field.input:focus { border-color: var(--admin-accent); outline: none; }
</style>
