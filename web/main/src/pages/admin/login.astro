---
// Strona logowania do panelu admin
import { validateLogin } from '../lib/auth';
import '../styles/admin.css';

let error = '';
if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const password = data.get('password')?.toString() || '';
  if (validateLogin(password)) {
    return new Response(null, {
      status: 302,
      headers: {
        'Location': '/admin',
        'Set-Cookie': `admin_token=${password}; Path=/; HttpOnly; SameSite=Lax; Max-Age=86400`,
      },
    });
  }
  error = 'Nieprawidłowe hasło';
}
---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PaganLinux — Login</title>
</head>
<body style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:var(--admin-bg);color:var(--admin-fg);font-family:Inter,system-ui,sans-serif;">
  <div style="width:380px;background:var(--admin-card);border:1px solid var(--admin-border);border-radius:16px;padding:2rem;">
    <h1 style="font-size:1.4rem;margin-bottom:0.3rem;text-align:center;">🐺 PaganLinux CMS</h1>
    <p style="color:var(--admin-muted);font-size:0.85rem;text-align:center;margin-bottom:1.5rem;">Panel administracyjny</p>

    {error && <div class="admin-alert error">{error}</div>}

    <form method="POST">
      <div class="admin-field">
        <label>Hasło administratora</label>
        <input type="password" name="password" placeholder="••••••••" autofocus required />
      </div>
      <button type="submit" class="admin-btn primary" style="width:100%;justify-content:center;padding:0.7rem;font-size:0.95rem;">
        🔐 Zaloguj
      </button>
    </form>
  </div>
</body>
</html>
