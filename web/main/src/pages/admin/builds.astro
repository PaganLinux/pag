---
// Admin — Historia budowania
import AdminLayout from '../../layouts/AdminLayout.astro';

const builds = [
  { id: 1, port: 'nginx', version: '1.26.0-r1', status: 'success', time: '2m 34s', date: '2025-01-10 14:32', log: 'OK' },
  { id: 2, port: 'firefox', version: '131.0-r1', status: 'error', time: '5m 12s', date: '2025-01-10 13:15', log: 'ERROR: link failed' },
  { id: 3, port: 'hyprland', version: '0.45.0-r1', status: 'success', time: '1m 48s', date: '2025-01-10 12:00', log: 'OK' },
];
---
<AdminLayout>
  <h1>🔄 Historia budowania</h1>
  <p class="subtitle">Logi i statusy budowania pakietów z pagports</p>

  <div style="display:flex;gap:0.6rem;margin-bottom:1rem;">
    <button class="admin-btn">🔄 Odśwież</button>
    <button class="admin-btn danger small">🗑️ Wyczyść historię</button>
  </div>

  <table class="admin-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Port</th>
        <th>Wersja</th>
        <th>Status</th>
        <th>Czas</th>
        <th>Data</th>
        <th>Log</th>
      </tr>
    </thead>
    <tbody>
      {builds.length === 0 ? (
        <tr><td colspan="7" class="empty">Brak historii budowania. <a href="/admin/ports">Uruchom pierwszy build →</a></td></tr>
      ) : builds.map(b => (
        <tr>
          <td>#{b.id}</td>
          <td><strong>{b.port}</strong></td>
          <td><span class="admin-tag green">{b.version}</span></td>
          <td>
            {b.status === 'success' && <span class="admin-tag green">✅ OK</span>}
            {b.status === 'error' && <span class="admin-tag red">❌ Błąd</span>}
            {b.status === 'running' && <span class="admin-tag yellow">🔄 Trwa</span>}
          </td>
          <td>{b.time}</td>
          <td>{b.date}</td>
          <td>
            <button class="admin-btn small" onclick="alert('{b.log}')">📄 Pokaż</button>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</AdminLayout>
