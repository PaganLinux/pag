---
// Admin — Pakiety .pag
import AdminLayout from '../../layouts/AdminLayout.astro';

const packages = [
  { name: '7zip', version: '24.09', repo: 'extra', size: '1.2 MB', built: '2024-12-01' },
  { name: 'nginx', version: '1.26.0', repo: 'core', size: '3.8 MB', built: '2024-12-05' },
  { name: 'hyprland', version: '0.45.0', repo: 'community', size: '8.1 MB', built: '2024-11-28' },
];
---
<AdminLayout>
  <h1>📦 Pakiety .pag</h1>
  <p class="subtitle">Zarządzanie pakietami w repozytorium</p>

  <div style="display:flex;gap:0.6rem;margin-bottom:1rem;">
    <a href="/admin/ports" class="admin-btn primary">🏗️ Zbuduj nowy</a>
    <button class="admin-btn">🔄 Odśwież</button>
  </div>

  <table class="admin-table">
    <thead>
      <tr>
        <th>Nazwa</th>
        <th>Wersja</th>
        <th>Repozytorium</th>
        <th>Rozmiar</th>
        <th>Zbudowano</th>
        <th>Akcje</th>
      </tr>
    </thead>
    <tbody>
      {packages.length === 0 ? (
        <tr><td colspan="6" class="empty">Brak pakietów. <a href="/admin/ports">Zbuduj pierwszy →</a></td></tr>
      ) : packages.map(pkg => (
        <tr>
          <td><strong>{pkg.name}</strong></td>
          <td><span class="admin-tag green">{pkg.version}</span></td>
          <td><span class="admin-tag blue">{pkg.repo}</span></td>
          <td>{pkg.size}</td>
          <td>{pkg.built}</td>
          <td style="display:flex;gap:0.3rem;">
            <button class="admin-btn small">📋 Info</button>
            <button class="admin-btn small danger">🗑️</button>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</AdminLayout>
