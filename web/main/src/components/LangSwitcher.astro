---
// Komponent: Przełącznik języka
import { supportedLangs, type Lang } from '../i18n/translations';
import { t, getLocaleFromUrl, getLocalizedPath, defaultLang } from '../i18n/utils';

const url = new URL(Astro.request.url);
const currentLocale = getLocaleFromUrl(url);
const currentPath = url.pathname;
---

<div class="lang-switcher">
  <button class="lang-btn" id="lang-btn" aria-label={t(currentLocale, `lang.${currentLocale}`)}>
    {supportedLangs.find(l => l === currentLocale)?.toUpperCase() || 'PL'}
    <span class="lang-arrow">▼</span>
  </button>
  <ul class="lang-dropdown" id="lang-dropdown">
    {supportedLangs.map(lang => (
      <li>
        <a
          href={getLocalizedPath(currentPath, lang)}
          class={lang === currentLocale ? 'active' : ''}
        >
          {t(currentLocale, `lang.${lang}`)}
        </a>
      </li>
    ))}
  </ul>
</div>

<script>
  // Toggle dropdown na kliknięcie
  const btn = document.getElementById('lang-btn');
  const dropdown = document.getElementById('lang-dropdown');
  if (btn && dropdown) {
    btn.addEventListener('click', () => {
      dropdown.classList.toggle('open');
    });
    // Zamknij po kliknięciu poza
    document.addEventListener('click', (e) => {
      if (!btn.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
        dropdown.classList.remove('open');
      }
    });
  }
</script>

<style>
  .lang-switcher {
    position: relative;
  }
  .lang-btn {
    background: var(--card);
    border: 1px solid var(--border);
    color: var(--fg);
    padding: 0.4rem 0.7rem;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    transition: border-color 0.2s;
    font-family: inherit;
  }
  .lang-btn:hover {
    border-color: var(--accent2);
  }
  .lang-arrow {
    font-size: 0.6rem;
    opacity: 0.5;
  }
  .lang-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 0.3rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    list-style: none;
    padding: 0.3rem 0;
    min-width: 180px;
    z-index: 200;
    box-shadow: 0 10px 30px rgba(0,0,0,0.4);
  }
  .lang-dropdown.open {
    display: block;
  }
  .lang-dropdown li a {
    display: block;
    padding: 0.5rem 1rem;
    color: var(--fg);
    text-decoration: none;
    font-size: 0.9rem;
    transition: background 0.15s;
  }
  .lang-dropdown li a:hover {
    background: rgba(124,58,237,0.1);
  }
  .lang-dropdown li a.active {
    color: var(--accent2);
    font-weight: 600;
    background: rgba(124,58,237,0.08);
  }
</style>
