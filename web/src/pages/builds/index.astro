---
// build.paganlinux.eu — Kolejka buildów i logi
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

const locale = Astro.currentLocale;

// Fetch builds from CMS API
let builds: any[] = [];
let error: string | null = null;

try {
  const apiBase = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000/api/v1';
  const res = await fetch(`${apiBase}/builds`);
  if (res.ok) {
    const data = await res.json();
    builds = data.builds || [];
  } else {
    error = `API returned ${res.status}`;
  }
} catch (e: any) {
  error = e.message;
}

const statusIcons: Record<string, string> = {
  queued: '⏳',
  running: '🔄',
  success: '✅',
  failed: '❌',
  cancelled: '🚫',
};

function formatDate(dateStr: string | null): string {
  if (!dateStr) return '—';
  return new Date(dateStr).toLocaleString();
}
---

<BaseLayout
  title={t(locale, 'builds.title')}
  description={t(locale, 'builds.subtitle')}
>
  <section class="page">
    <div class="page-header">
      <h1>{t(locale, 'builds.title')}</h1>
      <p class="subtitle">{t(locale, 'builds.subtitle')} · <span class="refresh-hint">{t(locale, 'builds.refresh')}</span></p>
    </div>

    {error && (
      <div class="error-banner">
        ⚠️ API niedostępne: {error}. <a href="https://cms.paganlinux.eu/builds">Przejdź do CMS</a>
      </div>
    )}

    <div class="table-wrap" id="buildsTable">
      <table>
        <thead>
          <tr>
            <th>{t(locale, 'builds.jobId')}</th>
            <th>{t(locale, 'builds.package')}</th>
            <th>{t(locale, 'builds.arch')}</th>
            <th>{t(locale, 'builds.status')}</th>
            <th>{t(locale, 'builds.started')}</th>
            <th>{t(locale, 'builds.finished')}</th>
          </tr>
        </thead>
        <tbody>
          {builds.map((b: any) => (
            <tr class={`row-${b.status}`}>
              <td><code class="job-id">{b.job_id?.slice(0, 16)}...</code></td>
              <td>
                <span class="pkg-name">{b.package_name || `#${b.package_id}`}</span>
                {b.package_version && <span class="pkg-ver">{b.package_version}</span>}
              </td>
              <td><code class="arch-tag">{b.arch}</code></td>
              <td>
                <span class="status-cell status-{b.status}">
                  {statusIcons[b.status] || '❓'} {b.status}
                </span>
              </td>
              <td class="date-cell">{formatDate(b.started_at)}</td>
              <td class="date-cell">{formatDate(b.finished_at)}</td>
            </tr>
          ))}
        </tbody>
      </table>

      {!error && builds.length === 0 && (
        <div class="empty">
          <p>{t(locale, 'builds.noBuilds')}</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  // Auto-refresh co 10 sekund
  setTimeout(() => { location.reload(); }, 10000);
</script>

<style>
  .page { max-width: 1200px; margin: 0 auto; padding: 4rem 2rem; }
  .page-header { margin-bottom: 2.5rem; }
  .page-header h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .subtitle { color: var(--fg-muted); font-size: 1.05rem; }
  .refresh-hint { color: #555; font-size: 0.85rem; }

  .table-wrap {
    background: var(--card); border: 1px solid var(--border);
    border-radius: var(--radius); overflow: hidden;
  }
  table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  th {
    text-align: left; padding: 0.75rem 1rem;
    background: rgba(0,0,0,0.3); border-bottom: 1px solid var(--border);
    font-size: 0.76rem; text-transform: uppercase; letter-spacing: 0.05em;
    color: var(--fg-muted);
  }
  td { padding: 0.7rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.03); }
  tr:last-child td { border-bottom: none; }
  .row-running { background: rgba(59,130,246,0.05); }
  .row-failed { background: rgba(239,68,68,0.06); }
  .row-success { background: rgba(16,185,129,0.03); }

  .job-id { font-size: 0.78rem; color: var(--fg-muted); font-family: monospace; }
  .pkg-name { font-weight: 600; }
  .pkg-ver { color: var(--fg-muted); margin-left: 0.4rem; font-size: 0.82rem; }
  .arch-tag {
    background: rgba(124,58,237,0.12); color: var(--accent2);
    padding: 0.1rem 0.45rem; border-radius: 3px; font-size: 0.78rem;
  }
  .status-cell { font-size: 0.85rem; }
  .status-success { color: #10b981; }
  .status-running { color: #3b82f6; }
  .status-failed { color: #ef4444; }
  .status-queued { color: #9ca3af; }
  .date-cell { font-size: 0.82rem; color: var(--fg-muted); white-space: nowrap; }

  .error-banner {
    background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3);
    border-radius: 10px; padding: 1rem 1.5rem; margin-bottom: 2rem;
    color: #fca5a5; font-size: 0.9rem;
  }
  .error-banner a { color: #fca5a5; text-decoration: underline; }
  .empty { text-align: center; padding: 4rem; color: var(--fg-muted); }
  @media (max-width: 768px) {
    th:nth-child(1), td:nth-child(1),
    th:nth-child(5), td:nth-child(5) { display: none; }
  }
</style>
