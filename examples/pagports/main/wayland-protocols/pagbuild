# PaganLinux Build Script (pagbuild)
# Wayland protocol definitions

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=wayland-protocols
pkgver=1.36
pkgrel=0
pkgdesc="Wayland protocol definitions"
url="https://wayland.freedesktop.org/"
arch="x86_64"
license="MIT"
makedepends="meson ninja wayland-dev"
depends="wayland"
source="https://gitlab.freedesktop.org/wayland/wayland-protocols/-/releases/1.36/downloads/wayland-protocols-1.36.tar.xz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    DESTDIR="$pkgdir" ninja -C build install
}

