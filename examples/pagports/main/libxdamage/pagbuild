# PaganLinux Build Script (pagbuild)
# X Damage extension library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libxdamage
pkgver=1.1.6
pkgrel=0
pkgdesc="X Damage extension library"
url="https://www.x.org/"
arch="x86_64"
license="MIT"
makedepends="gcc make xorgproto libx11-dev libxfixes-dev"
depends="xorgproto libx11 libxfixes"
subpackages="libxdamage-dev"
source="https://www.x.org/releases/individual/lib/libXdamage-1.1.6.tar.xz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

