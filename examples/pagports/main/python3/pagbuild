# PaganLinux Build Script (pagbuild)
# Python programming language

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=python3
pkgver=3.12.5
pkgrel=0
pkgdesc="Python programming language"
url="https://www.python.org/"
arch="x86_64"
license="PSF-2.0"
makedepends="gcc make"
depends=""
subpackages="python3-dev python3-doc"
source="https://www.python.org/ftp/python/3.12.5/Python-3.12.5.tar.xz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr --enable-shared && make
}

package() {
    make DESTDIR="$pkgdir" install
}

