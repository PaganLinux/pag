# PaganLinux Build Script (pagbuild)
# Cross-platform build system

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=cmake
pkgver=3.30.2
pkgrel=0
pkgdesc="Cross-platform build system"
url="https://cmake.org/"
arch="x86_64"
license="BSD-3-Clause"
makedepends="gcc make"
depends=""
source="https://github.com/Kitware/CMake/archive/v3.30.2.tar.gz"
builddir="$srcdir"

build() {
    ./bootstrap --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

