# PaganLinux Build Script (pagbuild)
# xrandr clone for wlroots compositors

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=wlr-randr
pkgver=0.4.1
pkgrel=0
pkgdesc="xrandr clone for wlroots compositors"
url="https://sr.ht/~emersion/wlr-randr/"
arch="x86_64"
license="MIT"
makedepends="meson ninja gcc wayland-dev"
depends="wayland"
source="https://git.sr.ht/~emersion/wlr-randr/archive/v0.4.1.tar.gz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    make DESTDIR="$pkgdir" install
}

