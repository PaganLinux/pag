# PaganLinux Build Script (pagbuild)
# Launcher/menu for wlroots compositors

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=wofi
pkgver=1.4.1
pkgrel=0
pkgdesc="Launcher/menu for wlroots compositors"
url="https://hg.sr.ht/~scoopta/wofi"
arch="x86_64"
license="GPL-3.0-or-later"
makedepends="meson ninja gcc wayland-dev gtk+3.0-dev"
depends="wayland gtk+3.0"
source="https://hg.sr.ht/~scoopta/wofi/archive/v1.4.1.tar.gz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    DESTDIR="$pkgdir" ninja -C build install
}

