# PaganLinux Build Script (pagbuild)
# Rust programming language

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=rust
pkgver=1.82.0
pkgrel=0
pkgdesc="Rust programming language"
url="https://www.rust-lang.org/"
arch="x86_64"
license="MIT OR Apache-2.0"
makedepends="gcc make cmake curl"
depends="gcc"
subpackages="rust-doc rust-src"
source="https://static.rust-lang.org/dist/rustc-1.82.0-src.tar.gz"
builddir="$srcdir"

build() {
    ./x.py build
}

package() {
    ./x.py install
}

