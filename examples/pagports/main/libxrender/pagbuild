# PaganLinux Build Script (pagbuild)
# X Rendering Extension library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libxrender
pkgver=0.9.11
pkgrel=0
pkgdesc="X Rendering Extension library"
url="https://www.x.org/"
arch="x86_64"
license="MIT"
makedepends="gcc make xorgproto libx11-dev"
depends="xorgproto libx11"
subpackages="libxrender-dev"
source="https://www.x.org/releases/individual/lib/libXrender-0.9.11.tar.xz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

