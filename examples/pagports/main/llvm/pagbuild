# PaganLinux Build Script (pagbuild)
# LLVM compiler infrastructure

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=llvm
pkgver=18.1.8
pkgrel=0
pkgdesc="LLVM compiler infrastructure"
url="https://llvm.org/"
arch="x86_64"
license="Apache-2.0"
makedepends="cmake gcc make ninja python3"
depends=""
subpackages="llvm-dev llvm-libs clang lld"
source="https://github.com/llvm/llvm-project/archive/llvmorg-18.1.8.tar.gz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr -DLLVM_ENABLE_PROJECTS=clang && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

