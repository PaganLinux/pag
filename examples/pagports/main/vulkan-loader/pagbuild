# PaganLinux Build Script (pagbuild)
# Vulkan Loader

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=vulkan-loader
pkgver=1.3.280
pkgrel=0
pkgdesc="Vulkan Loader"
url="https://github.com/KhronosGroup/Vulkan-Loader"
arch="x86_64"
license="Apache-2.0"
makedepends="cmake gcc make python3 vulkan-headers"
depends="vulkan-headers libx11 libxcb wayland"
subpackages="vulkan-loader-dev"
source="https://github.com/KhronosGroup/Vulkan-Loader/archive/v1.3.280.tar.gz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

