# PaganLinux Build Script (pagbuild)
# Wallpaper daemon for Wayland compositors

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=swaybg
pkgver=1.2.1
pkgrel=0
pkgdesc="Wallpaper daemon for Wayland compositors"
url="https://github.com/swaywm/swaybg"
arch="x86_64"
license="MIT"
makedepends="meson ninja gcc wayland-dev wayland-protocols cairo-dev"
depends="wayland cairo"
source="https://github.com/swaywm/swaybg/archive/v1.2.1.tar.gz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    make DESTDIR="$pkgdir" install
}

