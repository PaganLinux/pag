# PaganLinux Build Script (pagbuild)
# SSL/TLS toolkit

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=openssl
pkgver=3.3.1
pkgrel=0
pkgdesc="SSL/TLS toolkit"
url="https://www.openssl.org/"
arch="x86_64"
license="Apache-2.0"
makedepends="gcc make perl"
depends=""
subpackages="openssl-dev openssl-doc"
source="https://www.openssl.org/source/openssl-3.3.1.tar.gz"
builddir="$srcdir"

build() {
    ./Configure --prefix=/usr --openssldir=/etc/ssl shared && make
}

package() {
    make DESTDIR="$pkgdir" install
}

