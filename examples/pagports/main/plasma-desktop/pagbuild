# PaganLinux Build Script (pagbuild)
# KDE Plasma Desktop

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=plasma-desktop
pkgver=6.1.3
pkgrel=0
pkgdesc="KDE Plasma Desktop"
url="https://kde.org/plasma-desktop/"
arch="x86_64"
license="GPL-2.0-or-later"
makedepends="cmake gcc make ninja qt6-base-dev plasma-workspace-dev"
depends="qt6-base plasma-workspace"
source="https://download.kde.org/stable/plasma/6.1.3/plasma-desktop-6.1.3.tar.xz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

