# PaganLinux Build Script (pagbuild)
# Signal private messenger desktop

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=signal-desktop
pkgver=7.19.0
pkgrel=0
pkgdesc="Signal private messenger desktop"
url="https://signal.org/"
arch="x86_64"
license="AGPL-3.0-only"
makedepends="nodejs npm git"
depends="gtk+3.0 nss nspr libx11"
source="https://github.com/signalapp/Signal-Desktop/archive/v7.19.0.tar.gz"
builddir="$srcdir"

build() {
    npm install && npm run build
}

package() {
    make DESTDIR="$pkgdir" install
}

