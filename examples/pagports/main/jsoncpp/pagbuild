# PaganLinux Build Script (pagbuild)
# C++ JSON library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=jsoncpp
pkgver=1.9.5
pkgrel=0
pkgdesc="C++ JSON library"
url="https://github.com/open-source-parsers/jsoncpp"
arch="x86_64"
license="MIT"
makedepends="meson ninja gcc"
depends=""
subpackages="jsoncpp-dev"
source="https://github.com/open-source-parsers/jsoncpp/archive/1.9.5.tar.gz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    make DESTDIR="$pkgdir" install
}

