# PaganLinux Build Script (pagbuild)
# Audio editor and recorder

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=audacity
pkgver=3.6.1
pkgrel=0
pkgdesc="Audio editor and recorder"
url="https://www.audacityteam.org/"
arch="x86_64"
license="GPL-3.0-or-later"
makedepends="cmake gcc make ninja wxwidgets-dev"
depends="wxwidgets"
source="https://github.com/audacity/audacity/archive/Audacity-3.6.1.tar.gz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

