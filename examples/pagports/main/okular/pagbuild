# PaganLinux Build Script (pagbuild)
# KDE Document Viewer

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=okular
pkgver=24.05.2
pkgrel=0
pkgdesc="KDE Document Viewer"
url="https://okular.kde.org/"
arch="x86_64"
license="GPL-2.0-or-later"
makedepends="cmake gcc make ninja qt6-base-dev"
depends="qt6-base"
source="https://download.kde.org/stable/release-service/24.05.2/src/okular-24.05.2.tar.xz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

