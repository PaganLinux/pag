# PaganLinux Build Script (pagbuild)
# LibreOffice productivity suite

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libreoffice
pkgver=24.8.0
pkgrel=0
pkgdesc="LibreOffice productivity suite"
url="https://www.libreoffice.org/"
arch="x86_64"
license="MPL-2.0"
makedepends="gcc make java-jdk perl python3 gtk+3.0-dev"
depends="gtk+3.0 java-jre"
subpackages="libreoffice-calc libreoffice-writer libreoffice-impress"
source="https://download.documentfoundation.org/libreoffice/src/24.8.0/libreoffice-24.8.0.tar.xz"
builddir="$srcdir"

build() {
    ./autogen.sh --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

