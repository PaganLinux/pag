# PaganLinux Build Script (pagbuild)
# GNOME Adwaita icon theme

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=adwaita-icon-theme
pkgver=46.0
pkgrel=0
pkgdesc="GNOME Adwaita icon theme"
url="https://gitlab.gnome.org/GNOME/adwaita-icon-theme"
arch="x86_64"
license="LGPL-3.0-only OR CC-BY-SA-3.0"
makedepends="meson ninja"
depends=""
source="https://download.gnome.org/sources/adwaita-icon-theme/46/adwaita-icon-theme-46.0.tar.xz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    DESTDIR="$pkgdir" ninja -C build install
}

