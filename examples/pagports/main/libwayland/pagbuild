# PaganLinux Build Script (pagbuild)
# Wayland C library (libwayland-client/server)

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libwayland
pkgver=1.23.0
pkgrel=0
pkgdesc="Wayland C library (libwayland-client/server)"
url="https://wayland.freedesktop.org/"
arch="x86_64"
license="MIT"
makedepends="meson ninja gcc expat-dev libxml2-dev"
depends="expat libxml2"
subpackages="libwayland-dev"
source="https://gitlab.freedesktop.org/wayland/wayland/-/releases/1.23.0/downloads/wayland-1.23.0.tar.xz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr -Ddocumentation=false && ninja -C build
}

package() {
    make DESTDIR="$pkgdir" install
}

