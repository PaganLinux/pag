# PaganLinux Build Script (pagbuild)
# Mozilla Firefox web browser

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=firefox
pkgver=130.0
pkgrel=0
pkgdesc="Mozilla Firefox web browser"
url="https://www.mozilla.org/firefox/"
arch="x86_64"
license="MPL-2.0"
makedepends="rust nodejs gcc make nasm yasm mesa-dev libx11-dev libxcb-dev libxext-dev libxrender-dev libxrandr-dev libxtst-dev dbus-dev gtk+3.0-dev pulseaudio-dev"
depends="mesa libx11 libxcb libxext libxrender libxrandr dbus gtk+3.0 pulseaudio nss"
source="https://ftp.mozilla.org/pub/firefox/releases/130.0/source/firefox-130.0.source.tar.xz"
builddir="$srcdir"

build() {
    ./mach build
}

package() {
    ./mach install
}

