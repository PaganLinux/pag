maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=btop
pkgver=1.3.2
pkgrel=0
pkgdesc="Resource monitor (C++ version of bashtop)"
url="https://github.com/aristocratos/btop"
arch="x86_64"
license="Apache-2.0"
makedepends="gcc make"
depends=""
