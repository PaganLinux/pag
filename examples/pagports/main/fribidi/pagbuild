# PaganLinux Build Script (pagbuild)
# Free Implementation of the Unicode Bidirectional Algorithm

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=fribidi
pkgver=1.0.15
pkgrel=0
pkgdesc="Free Implementation of the Unicode Bidirectional Algorithm"
url="https://github.com/fribidi/fribidi"
arch="x86_64"
license="LGPL-2.1-or-later"
makedepends="meson ninja gcc"
depends=""
subpackages="fribidi-dev"
source="https://github.com/fribidi/fribidi/archive/v1.0.15.tar.gz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    make DESTDIR="$pkgdir" install
}

