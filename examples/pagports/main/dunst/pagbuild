# PaganLinux Build Script (pagbuild)
# Lightweight notification daemon

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=dunst
pkgver=1.9.2
pkgrel=0
pkgdesc="Lightweight notification daemon"
url="https://dunst-project.org/"
arch="x86_64"
license="BSD-3-Clause"
makedepends="gcc make libx11-dev libxext-dev libxrandr-dev pango-dev cairo-dev"
depends="libx11 libxext libxrandr pango cairo"
source="https://github.com/dunst-project/dunst/archive/v1.9.2.tar.gz"
builddir="$srcdir"

build() {
    make
}

package() {
    make PREFIX=/usr DESTDIR="$pkgdir" install
}

