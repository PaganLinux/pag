# PaganLinux Build Script (pagbuild)
# Mesa 3D Graphics Library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=mesa
pkgver=24.2.0
pkgrel=0
pkgdesc="Mesa 3D Graphics Library"
url="https://www.mesa3d.org/"
arch="x86_64"
license="MIT"
makedepends="meson ninja gcc llvm-dev libdrm-dev wayland-protocols libx11-dev libxext-dev libxfixes-dev libxrandr-dev libxxf86vm-dev zlib-dev expat-dev python3-mako"
depends="libdrm wayland libx11 libxext libxfixes libxrandr zlib"
subpackages="mesa-dev mesa-dri mesa-egl mesa-gbm mesa-gl mesa-vulkan"
source="https://archive.mesa3d.org/mesa-24.2.0.tar.xz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr -Dgallium-drivers=iris,crocus,zink,llvmpipe -Dvulkan-drivers=intel,amd,swrast -Dplatforms=x11,wayland && ninja -C build
}

package() {
    DESTDIR="$pkgdir" ninja -C build install
}

