# PaganLinux Build Script (pagbuild)
# Bluetooth protocol stack for Linux

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=bluez
pkgver=5.77
pkgrel=0
pkgdesc="Bluetooth protocol stack for Linux"
url="https://www.bluez.org/"
arch="x86_64"
license="GPL-2.0-or-later"
makedepends="gcc make"
depends=""
subpackages="bluez-dev"
source="https://mirrors.edge.kernel.org/pub/linux/bluetooth/bluez-5.77.tar.xz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

