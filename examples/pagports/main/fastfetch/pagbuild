# PaganLinux Build Script (pagbuild)
# Fast system information tool

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=fastfetch
pkgver=2.21.3
pkgrel=0
pkgdesc="Fast system information tool"
url="https://github.com/fastfetch-cli/fastfetch"
arch="x86_64"
license="MIT"
makedepends="cmake gcc make pkgconfig"
depends=""
source="https://github.com/fastfetch-cli/fastfetch/archive/2.21.3.tar.gz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

