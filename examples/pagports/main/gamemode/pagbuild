# PaganLinux Build Script (pagbuild)
# Optimise Linux system performance for gaming

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=gamemode
pkgver=1.8.1
pkgrel=0
pkgdesc="Optimise Linux system performance for gaming"
url="https://github.com/FeralInteractive/gamemode"
arch="x86_64"
license="BSD-3-Clause"
makedepends="meson ninja gcc"
depends=""
source="https://github.com/FeralInteractive/gamemode/archive/1.8.1.tar.gz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    make DESTDIR="$pkgdir" install
}

