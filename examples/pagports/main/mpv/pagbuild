# PaganLinux Build Script (pagbuild)
# Media player based on MPlayer

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=mpv
pkgver=0.38.0
pkgrel=0
pkgdesc="Media player based on MPlayer"
url="https://mpv.io/"
arch="x86_64"
license="GPL-2.0-or-later"
makedepends="meson ninja gcc ffmpeg-dev mesa-dev wayland-dev libx11-dev"
depends="ffmpeg mesa wayland libx11"
source="https://github.com/mpv-player/mpv/archive/v0.38.0.tar.gz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    DESTDIR="$pkgdir" ninja -C build install
}

