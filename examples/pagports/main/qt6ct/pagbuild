# PaganLinux Build Script (pagbuild)
# Qt6 Configuration Tool

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=qt6ct
pkgver=0.9
pkgrel=0
pkgdesc="Qt6 Configuration Tool"
url="https://github.com/trialuser02/qt6ct"
arch="x86_64"
license="BSD-2-Clause"
makedepends="cmake gcc make qt6-base-dev qt6-tools"
depends="qt6-base"
source="https://github.com/trialuser02/qt6ct/archive/0.9.tar.gz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

