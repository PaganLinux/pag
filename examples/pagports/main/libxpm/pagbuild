# PaganLinux Build Script (pagbuild)
# X Pixmap library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libxpm
pkgver=3.5.17
pkgrel=0
pkgdesc="X Pixmap library"
url="https://www.x.org/"
arch="x86_64"
license="MIT"
makedepends="gcc make xorgproto libx11-dev"
depends="xorgproto libx11"
subpackages="libxpm-dev"
source="https://www.x.org/releases/individual/lib/libXpm-3.5.17.tar.xz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

