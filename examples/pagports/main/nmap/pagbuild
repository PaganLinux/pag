# PaganLinux Build Script (pagbuild)
# Network discovery and security auditing

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=nmap
pkgver=7.95
pkgrel=0
pkgdesc="Network discovery and security auditing"
url="https://nmap.org/"
arch="x86_64"
license="GPL-2.0-only"
makedepends="gcc make openssl-dev"
depends="openssl"
source="https://nmap.org/dist/nmap-7.95.tar.bz2"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

