# PaganLinux Build Script (pagbuild)
# KDE File Manager

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=dolphin
pkgver=24.05.2
pkgrel=0
pkgdesc="KDE File Manager"
url="https://apps.kde.org/dolphin/"
arch="x86_64"
license="GPL-2.0-or-later"
makedepends="cmake gcc make ninja qt6-base-dev"
depends="qt6-base kio"
source="https://download.kde.org/stable/release-service/24.05.2/src/dolphin-24.05.2.tar.xz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

