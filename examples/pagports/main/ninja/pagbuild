# PaganLinux Build Script (pagbuild)
# Small build system with a focus on speed

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=ninja
pkgver=1.12.1
pkgrel=0
pkgdesc="Small build system with a focus on speed"
url="https://ninja-build.org/"
arch="x86_64"
license="Apache-2.0"
makedepends="cmake gcc make python3"
depends=""
source="https://github.com/ninja-build/ninja/archive/v1.12.1.tar.gz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

