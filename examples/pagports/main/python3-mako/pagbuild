# PaganLinux Build Script (pagbuild)
# Mako template library for Python

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=python3-mako
pkgver=1.3.5
pkgrel=0
pkgdesc="Mako template library for Python"
url="https://www.makotemplates.org/"
arch="x86_64"
license="MIT"
makedepends="python3"
depends="python3"
source="https://files.pythonhosted.org/packages/source/M/Mako/Mako-1.3.5.tar.gz"
builddir="$srcdir"

build() {
    python3 setup.py build
}

package() {
    python3 setup.py install --root="$pkgdir"
}

