# PaganLinux Build Script (pagbuild)
# X keyboard file manipulation library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libxkbfile
pkgver=1.1.3
pkgrel=0
pkgdesc="X keyboard file manipulation library"
url="https://www.x.org/"
arch="x86_64"
license="MIT"
makedepends="gcc make xorgproto libx11-dev"
depends="xorgproto libx11"
subpackages="libxkbfile-dev"
source="https://www.x.org/releases/individual/lib/libxkbfile-1.1.3.tar.xz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

