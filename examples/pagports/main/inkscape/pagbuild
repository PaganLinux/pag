# PaganLinux Build Script (pagbuild)
# Vector graphics editor

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=inkscape
pkgver=1.3.2
pkgrel=0
pkgdesc="Vector graphics editor"
url="https://inkscape.org/"
arch="x86_64"
license="GPL-2.0-or-later"
makedepends="cmake gcc make gtk+3.0-dev"
depends="gtk+3.0"
source="https://inkscape.org/gallery/item/44616/inkscape-1.3.2.tar.xz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

