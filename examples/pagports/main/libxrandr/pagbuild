# PaganLinux Build Script (pagbuild)
# X RandR extension library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libxrandr
pkgver=1.5.4
pkgrel=0
pkgdesc="X RandR extension library"
url="https://www.x.org/"
arch="x86_64"
license="MIT"
makedepends="gcc make xorgproto libx11-dev libxrender-dev libxext-dev"
depends="xorgproto libx11 libxrender libxext"
subpackages="libxrandr-dev"
source="https://www.x.org/releases/individual/lib/libXrandr-1.5.4.tar.xz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

