# PaganLinux Build Script (pagbuild)
# X Keyboard Configuration Database

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=xkeyboard-config
pkgver=2.42
pkgrel=0
pkgdesc="X Keyboard Configuration Database"
url="https://www.freedesktop.org/wiki/Software/XKeyboardConfig/"
arch="x86_64"
license="MIT"
makedepends="meson ninja"
depends="xorgproto"
source="https://www.x.org/releases/individual/data/xkeyboard-config/xkeyboard-config-2.42.tar.xz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    make DESTDIR="$pkgdir" install
}

