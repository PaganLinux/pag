# PaganLinux Build Script (pagbuild)
# XDG Desktop Portal KDE backend

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=xdg-desktop-portal-kde
pkgver=6.1.3
pkgrel=0
pkgdesc="XDG Desktop Portal KDE backend"
url="https://invent.kde.org/plasma/xdg-desktop-portal-kde"
arch="x86_64"
license="LGPL-2.0-or-later"
makedepends="cmake gcc make ninja qt6-base-dev"
depends="qt6-base xdg-desktop-portal"
source="https://download.kde.org/stable/plasma/6.1.3/xdg-desktop-portal-kde-6.1.3.tar.xz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

