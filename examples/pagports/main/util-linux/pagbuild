# PaganLinux Build Script (pagbuild)
# Linux system utilities

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=util-linux
pkgver=2.40.2
pkgrel=0
pkgdesc="Linux system utilities"
url="https://github.com/util-linux/util-linux"
arch="x86_64"
license="GPL-2.0-or-later"
makedepends="gcc make"
depends=""
subpackages="util-linux-dev"
source="https://mirrors.edge.kernel.org/pub/linux/utils/util-linux/v2.40/util-linux-2.40.2.tar.xz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

