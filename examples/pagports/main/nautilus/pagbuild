# PaganLinux Build Script (pagbuild)
# GNOME file manager

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=nautilus
pkgver=46.2
pkgrel=0
pkgdesc="GNOME file manager"
url="https://apps.gnome.org/Nautilus/"
arch="x86_64"
license="GPL-3.0-or-later"
makedepends="meson ninja gcc gtk+3.0-dev"
depends="gtk+3.0"
source="https://download.gnome.org/sources/nautilus/46/nautilus-46.2.tar.xz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    make DESTDIR="$pkgdir" install
}

