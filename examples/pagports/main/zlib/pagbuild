# PaganLinux Build Script (pagbuild)
# Compression library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=zlib
pkgver=1.3.1
pkgrel=0
pkgdesc="Compression library"
url="https://zlib.net/"
arch="x86_64"
license="Zlib"
makedepends="gcc make"
depends=""
subpackages="zlib-dev"
source="https://zlib.net/zlib-1.3.1.tar.gz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

