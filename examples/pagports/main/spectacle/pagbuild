# PaganLinux Build Script (pagbuild)
# KDE Screenshot Tool

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=spectacle
pkgver=24.05.2
pkgrel=0
pkgdesc="KDE Screenshot Tool"
url="https://apps.kde.org/spectacle/"
arch="x86_64"
license="GPL-2.0-or-later"
makedepends="cmake gcc make ninja qt6-base-dev"
depends="qt6-base"
source="https://download.kde.org/stable/release-service/24.05.2/src/spectacle-24.05.2.tar.xz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

