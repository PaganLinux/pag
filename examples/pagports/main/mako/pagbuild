# PaganLinux Build Script (pagbuild)
# Lightweight Wayland notification daemon

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=mako
pkgver=1.9.0
pkgrel=0
pkgdesc="Lightweight Wayland notification daemon"
url="https://github.com/emersion/mako"
arch="x86_64"
license="MIT"
makedepends="meson ninja gcc wayland-dev pango-dev cairo-dev"
depends="wayland pango cairo"
source="https://github.com/emersion/mako/archive/v1.9.0.tar.gz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    make DESTDIR="$pkgdir" install
}

