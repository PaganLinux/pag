# PaganLinux Build Script (pagbuild)
# Xinerama extension library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libxinerama
pkgver=1.1.5
pkgrel=0
pkgdesc="Xinerama extension library"
url="https://www.x.org/"
arch="x86_64"
license="MIT"
makedepends="gcc make xorgproto libx11-dev libxext-dev"
depends="xorgproto libx11 libxext"
subpackages="libxinerama-dev"
source="https://www.x.org/releases/individual/lib/libXinerama-1.1.5.tar.xz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

