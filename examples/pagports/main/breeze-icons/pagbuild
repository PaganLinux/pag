# PaganLinux Build Script (pagbuild)
# KDE Breeze icon theme

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=breeze-icons
pkgver=6.1.0
pkgrel=0
pkgdesc="KDE Breeze icon theme"
url="https://kde.org/"
arch="x86_64"
license="LGPL-3.0-only"
makedepends="cmake gcc make ninja"
depends=""
source="https://download.kde.org/stable/frameworks/6.1.0/breeze-icons-6.1.0.tar.xz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

