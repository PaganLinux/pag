# PaganLinux Build Script (pagbuild)
# JPEG image codec library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libjpeg-turbo
pkgver=3.0.3
pkgrel=0
pkgdesc="JPEG image codec library"
url="https://libjpeg-turbo.org/"
arch="x86_64"
license="IJG"
makedepends="cmake gcc make nasm"
depends=""
subpackages="libjpeg-turbo-dev"
source="https://github.com/libjpeg-turbo/libjpeg-turbo/archive/3.0.3.tar.gz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

