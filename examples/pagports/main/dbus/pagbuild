# PaganLinux Build Script (pagbuild)
# D-Bus message bus system

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=dbus
pkgver=1.14.10
pkgrel=0
pkgdesc="D-Bus message bus system"
url="https://www.freedesktop.org/wiki/Software/dbus/"
arch="x86_64"
license="AFL-2.1 OR GPL-2.0-or-later"
makedepends="meson ninja gcc expat-dev"
depends=""
subpackages="dbus-dev dbus-x11 dbus-doc"
source="https://dbus.freedesktop.org/releases/dbus/dbus-1.14.10.tar.xz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    DESTDIR="$pkgdir" ninja -C build install
}

