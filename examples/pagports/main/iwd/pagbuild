# PaganLinux Build Script (pagbuild)
# Wireless daemon for Linux

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=iwd
pkgver=2.19
pkgrel=0
pkgdesc="Wireless daemon for Linux"
url="https://iwd.wiki.kernel.org/"
arch="x86_64"
license="LGPL-2.1-or-later"
makedepends="gcc make"
depends=""
source="https://git.kernel.org/pub/scm/network/wireless/iwd.git/snapshot/iwd-2.19.tar.gz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

