# PaganLinux Build Script (pagbuild)
# Windows compatibility layer

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=wine
pkgver=9.14
pkgrel=0
pkgdesc="Windows compatibility layer"
url="https://www.winehq.org/"
arch="x86_64"
license="LGPL-2.1-or-later"
makedepends="gcc make flex bison"
depends="libx11 libxcb mesa"
source="https://gitlab.winehq.org/wine/wine/-/archive/wine-9.14/wine-wine-9.14.tar.gz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

