# PaganLinux Build Script (pagbuild)
# Spotify music streaming client

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=spotify
pkgver=1.2.42
pkgrel=0
pkgdesc="Spotify music streaming client"
url="https://www.spotify.com/"
arch="x86_64"
license="custom:proprietary"
makedepends=""
depends="gtk+3.0 nss nspr libx11"
source="https://repository-origin.spotify.com/pool/non-free/s/spotify-client/spotify-client_1.2.42_amd64.deb"
builddir="$srcdir"

# Binary package — no build step
build() {
    mkdir -p "$pkgdir"/usr/bin
    ar x "$srcdir"/*.deb && tar -xf data.tar.* -C "$pkgdir"/
}

