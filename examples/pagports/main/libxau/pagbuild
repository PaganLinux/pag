# PaganLinux Build Script (pagbuild)
# X11 authorisation library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libxau
pkgver=1.0.11
pkgrel=0
pkgdesc="X11 authorisation library"
url="https://www.x.org/"
arch="x86_64"
license="MIT"
makedepends="gcc make xorgproto"
depends="xorgproto"
subpackages="libxau-dev"
source="https://www.x.org/releases/individual/lib/libXau-1.0.11.tar.xz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

