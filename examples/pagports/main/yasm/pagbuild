# PaganLinux Build Script (pagbuild)
# Yasm assembler

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=yasm
pkgver=1.3.0
pkgrel=0
pkgdesc="Yasm assembler"
url="https://yasm.tortall.net/"
arch="x86_64"
license="BSD"
makedepends="gcc make"
depends=""
source="https://www.tortall.net/projects/yasm/releases/yasm-1.3.0.tar.gz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

