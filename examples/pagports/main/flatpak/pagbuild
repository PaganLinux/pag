# PaganLinux Build Script (pagbuild)
# Flatpak application framework

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=flatpak
pkgver=1.15.9
pkgrel=0
pkgdesc="Flatpak application framework"
url="https://flatpak.org/"
arch="x86_64"
license="LGPL-2.1-or-later"
makedepends="meson ninja gcc"
depends=""
source="https://github.com/flatpak/flatpak/archive/1.15.9.tar.gz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    make DESTDIR="$pkgdir" install
}

