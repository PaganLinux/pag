# PaganLinux Build Script (pagbuild)
# X Fixes extension library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libxfixes
pkgver=6.0.1
pkgrel=0
pkgdesc="X Fixes extension library"
url="https://www.x.org/"
arch="x86_64"
license="MIT"
makedepends="gcc make xorgproto libx11-dev"
depends="xorgproto libx11"
subpackages="libxfixes-dev"
source="https://www.x.org/releases/individual/lib/libXfixes-6.0.1.tar.xz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

