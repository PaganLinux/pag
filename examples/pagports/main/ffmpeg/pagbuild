# PaganLinux Build Script (pagbuild)
# Complete multimedia framework

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=ffmpeg
pkgver=7.0.1
pkgrel=0
pkgdesc="Complete multimedia framework"
url="https://ffmpeg.org/"
arch="x86_64"
license="GPL-3.0-or-later"
makedepends="gcc make nasm yasm"
depends=""
subpackages="ffmpeg-dev ffmpeg-libs"
source="https://ffmpeg.org/releases/ffmpeg-7.0.1.tar.xz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr --enable-shared && make
}

package() {
    make DESTDIR="$pkgdir" install
}

