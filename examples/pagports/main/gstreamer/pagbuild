# PaganLinux Build Script (pagbuild)
# GStreamer multimedia framework

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=gstreamer
pkgver=1.24.6
pkgrel=0
pkgdesc="GStreamer multimedia framework"
url="https://gstreamer.freedesktop.org/"
arch="x86_64"
license="LGPL-2.1-or-later"
makedepends="meson ninja gcc"
depends=""
subpackages="gstreamer-dev"
source="https://gstreamer.freedesktop.org/src/gstreamer/gstreamer-1.24.6.tar.xz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    make DESTDIR="$pkgdir" install
}

