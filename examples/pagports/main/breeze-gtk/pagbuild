# PaganLinux Build Script (pagbuild)
# KDE Breeze GTK theme

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=breeze-gtk
pkgver=6.1.3
pkgrel=0
pkgdesc="KDE Breeze GTK theme"
url="https://kde.org/plasma-desktop/"
arch="x86_64"
license="GPL-2.0-or-later"
makedepends="cmake gcc make ninja gtk+3.0-dev"
depends="gtk+3.0 breeze"
source="https://download.kde.org/stable/plasma/6.1.3/breeze-gtk-6.1.3.tar.xz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

