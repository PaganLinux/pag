# PaganLinux Build Script (pagbuild)
# Improved tiling window manager

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=i3
pkgver=4.23
pkgrel=0
pkgdesc="Improved tiling window manager"
url="https://i3wm.org/"
arch="x86_64"
license="BSD-3-Clause"
makedepends="meson ninja gcc libx11-dev libxcb-dev xorgproto cairo-dev pango-dev"
depends="libx11 libxcb xorgproto cairo pango"
subpackages="i3status i3lock"
source="https://i3wm.org/downloads/i3-4.23.tar.xz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    make DESTDIR="$pkgdir" install
}

