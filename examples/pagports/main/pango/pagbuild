# PaganLinux Build Script (pagbuild)
# Text layout and rendering library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=pango
pkgver=1.54.0
pkgrel=0
pkgdesc="Text layout and rendering library"
url="https://pango.gnome.org/"
arch="x86_64"
license="LGPL-2.1-or-later"
makedepends="meson ninja gcc cairo-dev harfbuzz-dev"
depends="cairo harfbuzz fribidi"
subpackages="pango-dev"
source="https://download.gnome.org/sources/pango/1.54/pango-1.54.0.tar.xz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    DESTDIR="$pkgdir" ninja -C build install
}

