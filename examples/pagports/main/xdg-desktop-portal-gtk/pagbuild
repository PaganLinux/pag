# PaganLinux Build Script (pagbuild)
# XDG Desktop Portal GTK backend

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=xdg-desktop-portal-gtk
pkgver=1.15.1
pkgrel=0
pkgdesc="XDG Desktop Portal GTK backend"
url="https://github.com/flatpak/xdg-desktop-portal-gtk"
arch="x86_64"
license="LGPL-2.1-or-later"
makedepends="meson ninja gcc gtk+3.0-dev"
depends="gtk+3.0 xdg-desktop-portal"
source="https://github.com/flatpak/xdg-desktop-portal-gtk/archive/1.15.1.tar.gz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    make DESTDIR="$pkgdir" install
}

