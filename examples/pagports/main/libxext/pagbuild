# PaganLinux Build Script (pagbuild)
# X11 miscellaneous extensions library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libxext
pkgver=1.3.6
pkgrel=0
pkgdesc="X11 miscellaneous extensions library"
url="https://www.x.org/"
arch="x86_64"
license="MIT"
makedepends="gcc make xorgproto libx11-dev"
depends="xorgproto libx11"
subpackages="libxext-dev"
source="https://www.x.org/releases/individual/lib/libXext-1.3.6.tar.xz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

