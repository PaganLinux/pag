# PaganLinux Build Script (pagbuild)
# XML parsing library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libxml2
pkgver=2.13.3
pkgrel=0
pkgdesc="XML parsing library"
url="https://gitlab.gnome.org/GNOME/libxml2"
arch="x86_64"
license="MIT"
makedepends="meson ninja gcc"
depends=""
subpackages="libxml2-dev"
source="https://download.gnome.org/sources/libxml2/2.13/libxml2-2.13.3.tar.xz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    make DESTDIR="$pkgdir" install
}

