# PaganLinux Build Script (pagbuild)
# Network connection manager

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=networkmanager
pkgver=1.48.2
pkgrel=0
pkgdesc="Network connection manager"
url="https://networkmanager.dev/"
arch="x86_64"
license="GPL-2.0-or-later"
makedepends="meson ninja gcc dbus-dev"
depends="dbus iwd"
subpackages="networkmanager-dev networkmanager-wifi"
source="https://download.gnome.org/sources/NetworkManager/1.48/NetworkManager-1.48.2.tar.xz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    DESTDIR="$pkgdir" ninja -C build install
}

