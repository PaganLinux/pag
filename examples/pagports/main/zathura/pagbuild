# PaganLinux Build Script (pagbuild)
# Minimalistic document viewer

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=zathura
pkgver=0.5.6
pkgrel=0
pkgdesc="Minimalistic document viewer"
url="https://pwmt.org/projects/zathura/"
arch="x86_64"
license="Zlib"
makedepends="meson ninja gcc gtk+3.0-dev"
depends="gtk+3.0"
source="https://pwmt.org/projects/zathura/download/zathura-0.5.6.tar.xz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    make DESTDIR="$pkgdir" install
}

