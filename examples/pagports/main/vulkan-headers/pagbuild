# PaganLinux Build Script (pagbuild)
# Vulkan Header files

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=vulkan-headers
pkgver=1.3.280
pkgrel=0
pkgdesc="Vulkan Header files"
url="https://github.com/KhronosGroup/Vulkan-Headers"
arch="x86_64"
license="Apache-2.0"
makedepends="cmake gcc make"
depends=""
source="https://github.com/KhronosGroup/Vulkan-Headers/archive/v1.3.280.tar.gz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

