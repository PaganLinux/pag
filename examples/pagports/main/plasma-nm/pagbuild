# PaganLinux Build Script (pagbuild)
# KDE Plasma Network Manager applet

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=plasma-nm
pkgver=6.1.3
pkgrel=0
pkgdesc="KDE Plasma Network Manager applet"
url="https://kde.org/plasma-desktop/"
arch="x86_64"
license="GPL-2.0-or-later"
makedepends="cmake gcc make ninja qt6-base-dev plasma-workspace-dev networkmanager-dev"
depends="qt6-base plasma-workspace networkmanager"
source="https://download.kde.org/stable/plasma/6.1.3/plasma-nm-6.1.3.tar.xz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

