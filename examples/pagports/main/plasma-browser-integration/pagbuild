# PaganLinux Build Script (pagbuild)
# KDE Plasma browser integration

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=plasma-browser-integration
pkgver=6.1.3
pkgrel=0
pkgdesc="KDE Plasma browser integration"
url="https://kde.org/plasma-desktop/"
arch="x86_64"
license="GPL-3.0-or-later"
makedepends="cmake gcc make ninja qt6-base-dev"
depends="qt6-base"
source="https://download.kde.org/stable/plasma/6.1.3/plasma-browser-integration-6.1.3.tar.xz"
builddir="$srcdir"

build() {
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr && cmake --build build
}

package() {
    cmake --install build --prefix="$pkgdir"/usr
}

