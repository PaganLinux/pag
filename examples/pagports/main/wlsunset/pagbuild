# PaganLinux Build Script (pagbuild)
# Day/night gamma adjustments for Wayland

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=wlsunset
pkgver=0.4.0
pkgrel=0
pkgdesc="Day/night gamma adjustments for Wayland"
url="https://sr.ht/~kennylevinsen/wlsunset/"
arch="x86_64"
license="MIT"
makedepends="meson ninja gcc wayland-dev"
depends="wayland"
source="https://git.sr.ht/~kennylevinsen/wlsunset/archive/0.4.0.tar.gz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    make DESTDIR="$pkgdir" install
}

