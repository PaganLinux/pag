# PaganLinux Build Script (pagbuild)
# X Composite extension library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libxcomposite
pkgver=0.4.6
pkgrel=0
pkgdesc="X Composite extension library"
url="https://www.x.org/"
arch="x86_64"
license="MIT"
makedepends="gcc make xorgproto libx11-dev libxfixes-dev"
depends="xorgproto libx11 libxfixes"
subpackages="libxcomposite-dev"
source="https://www.x.org/releases/individual/lib/libXcomposite-0.4.6.tar.xz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

