# PaganLinux Build Script (pagbuild)
# wxWidgets GUI toolkit

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=wxwidgets
pkgver=3.2.5
pkgrel=0
pkgdesc="wxWidgets GUI toolkit"
url="https://www.wxwidgets.org/"
arch="x86_64"
license="wxWindows"
makedepends="gcc make gtk+3.0-dev"
depends="gtk+3.0"
subpackages="wxwidgets-dev"
source="https://github.com/wxWidgets/wxWidgets/archive/v3.2.5.tar.gz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

