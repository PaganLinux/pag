# PaganLinux Build Script (pagbuild)
# X11 Screen Saver extension library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libxscrnsaver
pkgver=1.2.4
pkgrel=0
pkgdesc="X11 Screen Saver extension library"
url="https://www.x.org/"
arch="x86_64"
license="MIT"
makedepends="gcc make xorgproto libx11-dev libxext-dev"
depends="xorgproto libx11 libxext"
subpackages="libxscrnsaver-dev"
source="https://www.x.org/releases/individual/lib/libXScrnSaver-1.2.4.tar.xz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

