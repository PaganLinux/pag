# PaganLinux Build Script (pagbuild)
# X11 client-side library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libx11
pkgver=1.8.9
pkgrel=0
pkgdesc="X11 client-side library"
url="https://www.x.org/"
arch="x86_64"
license="MIT"
makedepends="meson ninja gcc xorgproto libxcb-dev"
depends="xorgproto libxcb"
subpackages="libx11-dev"
source="https://www.x.org/releases/individual/lib/libX11-1.8.9.tar.xz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr && ninja -C build
}

package() {
    DESTDIR="$pkgdir" ninja -C build install
}

