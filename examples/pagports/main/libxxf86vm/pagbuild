# PaganLinux Build Script (pagbuild)
# X11 XFree86 video mode extension library

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=libxxf86vm
pkgver=1.1.5
pkgrel=0
pkgdesc="X11 XFree86 video mode extension library"
url="https://www.x.org/"
arch="x86_64"
license="MIT"
makedepends="gcc make xorgproto libx11-dev libxext-dev"
depends="xorgproto libx11 libxext"
subpackages="libxxf86vm-dev"
source="https://www.x.org/releases/individual/lib/libXxf86vm-1.1.5.tar.xz"
builddir="$srcdir"

build() {
    ./configure --prefix=/usr && make
}

package() {
    make DESTDIR="$pkgdir" install
}

