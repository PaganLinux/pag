# PaganLinux Build Script (pagbuild)
# Multimedia processing graph

maintainer="PaganLinux Team <team@paganlinux.eu>"
pkgname=pipewire
pkgver=1.2.1
pkgrel=0
pkgdesc="Multimedia processing graph"
url="https://pipewire.org/"
arch="x86_64"
license="MIT"
makedepends="meson ninja gcc dbus-dev"
depends="dbus"
subpackages="pipewire-dev pipewire-pulse pipewire-jack"
source="https://gitlab.freedesktop.org/pipewire/pipewire/-/archive/1.2.1/pipewire-1.2.1.tar.gz"
builddir="$srcdir"

build() {
    meson setup build -Dprefix=/usr -Dsession-managers=[] && ninja -C build
}

package() {
    DESTDIR="$pkgdir" ninja -C build install
}

